# Configuration pour Docker
# Copiez ce fichier en .env et personnalisez selon vos besoins

# Display X11 - généralement :0 ou :1
DISPLAY=:0

# Nom du conteneur (optionnel)
CONTAINER_NAME=ssh-key-generator

# Politique de redémarrage du conteneur
# Options: no, always, on-failure, unless-stopped
RESTART_POLICY=unless-stopped

# Dossier local pour récupérer les clés générées
OUTPUT_DIR=./generated-keys

# Options PyQt5 pour l'affichage (si problèmes graphiques)
# QT_AUTO_SCREEN_SCALE_FACTOR=0
# QT_SCALE_FACTOR=1
# QT_QPA_PLATFORM=xcb
